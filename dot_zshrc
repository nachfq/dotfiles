# ~/.zshrc (loader)

# Core interactive opts
setopt PROMPT_SUBST

# Load modules (order matters)
for f in \
  "$HOME/.config/zsh/history.zsh" \
  "$HOME/.config/zsh/keybinds.zsh" \
  "$HOME/.config/zsh/completion.zsh" \
  "$HOME/.config/zsh/prompt.zsh" \
  "$HOME/.config/zsh/git-prompt.zsh" \
  "$HOME/.config/zsh/aliases.zsh" \
  "$HOME/.config/zsh/private-aliases.zsh" \
  "$HOME/.config/zsh/tools.zsh"
do
  [ -f "$f" ] && source "$f"
done
